{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":rebaseStalePrs"
  ],
  "terraform": {},
  "pre-commit": {
    "enabled": true
  },
  "argocd": {
    "managerFilePatterns": [
      "/gitops/apps/.+\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/gitops/config/postgres/values\\.yaml$/"
      ],
      "matchStrings": [
        "imageName:\\s*(?<depName>ghcr\\.io/cloudnative-pg/postgresql):(?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "timezone": "America/Sao_Paulo",
  "schedule": [
    "after 3am and before 7am on Monday"
  ],
  "packageRules": [
    {
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit hooks"
    },
    {
      "matchManagers": ["terraform"],
      "matchDepTypes": ["provider"],
      "groupName": "terraform providers"
    },
    {
      "matchManagers": ["terraform"],
      "matchDepTypes": ["module"],
      "groupName": "terraform modules"
    },
    {
      "matchManagers": ["argocd"],
      "groupName": "helm charts"
    }
  ]
}
