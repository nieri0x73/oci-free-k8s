{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":rebaseStalePrs"
  ],
  "terraform": {},
  "pre-commit": {
    "enabled": true
  },
  "argocd": {
    "managerFilePatterns": [
      "/gitops/apps/.+\\.yaml$/"
    ]
  },
  "timezone": "America/Sao_Paulo",
  "schedule": [
    "after 3am and before 4am every weekday"
  ],
  "prHourlyLimit": 3,
  "packageRules": [
    {
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit hooks"
    },
    {
      "matchManagers": ["terraform"],
      "matchDepTypes": ["provider"],
      "groupName": "terraform providers"
    },
    {
      "matchManagers": ["terraform"],
      "matchDepTypes": ["module"],
      "groupName": "terraform modules"
    },
    {
      "matchManagers": ["argocd"],
      "matchFileNames": ["gitops/apps/**"],
      "groupName": "{{replace '\\.yaml$' '' (replace '^gitops/apps/' '' packageFile)}}",
      "commitMessageTopic": "{{replace '\\.yaml$' '' (replace '^gitops/apps/' '' packageFile)}}"
    }
  ]
}
